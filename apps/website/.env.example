# One RPC per cluster. Both must be Photon-capable (Helius / Triton) — the
# Lookup/Verify pages read compressed PDAs, and the public
# api.mainnet-beta.solana.com fallback will NOT serve those reads. When a
# cluster's var is unset, it falls back to that cluster's public default.

# Used when the cluster toggle = mainnet
# VITE_CC_VRF_MAINNET_RPC_URL=https://your-helius-or-triton-mainnet-rpc/?api-key=YOUR_KEY

# Used when the cluster toggle = devnet (and by the wallet demo)
# VITE_CC_VRF_DEVNET_RPC_URL=https://your-helius-or-triton-devnet-rpc/?api-key=YOUR_KEY
