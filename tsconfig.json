{
  "compilerOptions": {
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2023"],
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "programs/**/tests/**/*.ts",
    "target/types/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist", "target"]
}
